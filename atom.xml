    <title>Flink2019</title>
    <link href="https://staticor.github.io/2019/02/23/Flink2019/"/>
    <id>https://staticor.github.io/2019/02/23/Flink2019/</id>
    <published>2019-02-23T09:43:14.000Z</published>
    <updated>2019-02-26T12:59:08.905Z</updated>
    
